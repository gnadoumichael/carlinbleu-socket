{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "craue/twigextensions-bundle": "^2.9",
        "doctrine/annotations": "^1.0",
        "doctrine/doctrine-bundle": "^2.8",
        "doctrine/doctrine-migrations-bundle": "^3.2",
        "doctrine/orm": "^2.14",
        "dompdf/dompdf": "^2.0",
        "friendsofsymfony/ckeditor-bundle": "^2.6",
        "intervention/image": "^2.7",
        "lexik/jwt-authentication-bundle": "^2.16",
        "mobiledetect/mobiledetectlib": "^4.8",
        "nelmio/cors-bundle": "^2.2",
        "phpdocumentor/reflection-docblock": "^5.3",
        "phpoffice/phpspreadsheet": "^5.2",
        "phpstan/phpdoc-parser": "^1.16",
        "symfony/asset": "6.4.*|7.2.*",
        "symfony/cache": "7.2.*",
        "symfony/console": "7.2.*",
        "symfony/dotenv": "7.2.*",
        "symfony/flex": "^2",
        "symfony/form": "6.4.*|7.2.*",
        "symfony/http-client": "6.4.*",
        "symfony/mailer": "6.4.*",
        "symfony/messenger": "7.2.*",
        "symfony/monolog-bundle": "^3.8",
        "symfony/password-hasher": "7.2.*",
        "symfony/property-access": "6.4.*|7.2.*",
        "symfony/property-info": "6.4.*",
        "symfony/rate-limiter": "7.2.*",
        "symfony/runtime": "7.2.*",
        "symfony/security-bundle": "6.4.*|7.2.*",
        "symfony/serializer": "7.2.*",
        "symfony/translation": "7.2.*",
        "symfony/twig-bundle": "6.4.*|7.2.*",
        "symfony/validator": "6.4.*|7.2.*",
        "symfony/webpack-encore-bundle": "^1.16",
        "symfony/yaml": "7.2.*",
        "symfonycasts/reset-password-bundle": "^1.16",
        "symfonycasts/verify-email-bundle": "*",
        "twig/extra-bundle": "^2.12|^3.0",
        "twig/string-extra": "^3.7",
        "twig/twig": "^2.12|^3.0",
      "ext-curl": "*"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "ckeditor:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "6.4.*"
        }
    },
    "require-dev": {
        "rector/rector": "^0.15.10",
        "roave/security-advisories": "dev-latest",
        "symfony/maker-bundle": "*",
        "symfony/stopwatch": "7.2.*",
        "symfony/var-exporter": "7.2.*",
        "symfony/web-profiler-bundle": "7.2.*"
    }
}
