<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta http-equiv="Expires" CONTENT="Fri, 01 Jan 1990 00:00:00 GMT">
    <meta http-equiv="Cache-Control"
          CONTENT="private, no-store, max-age=0, no-cache, must-revalidate, post-check=0, pre-check=0">
    <meta http-equiv="Pragma" CONTENT="no-cache">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description"
          content="Devis, Chantier, Bon de commande, Bon de caisse, articles, Planning, Gestionnaire de stock, Facture">
    <meta name="author" content="carliin.com">
    <link rel="shortcut icon" href="{{ asset('img/cbleu.png') }}">
    <title>CarlinBleu - SHOWROOMS & PROJETS</title>
    {% block stylesheets %}
        <link href="{{ asset('https://carlinbleu.com/carlinbleu/public/build/css/sb-admin-2.min.css') }}" rel="stylesheet">
        <link href="{{ asset('https://carlinbleu.com/carlinbleu/public/build/css/all.css') }}" rel="stylesheet">
        <link href="{{ asset('https://carlinbleu.com/carlinbleu/public/build/css/style.css') }}" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
        <style>
            .mignons{
                width: 880px !important;
                margin: auto;
            }
        </style>
    {% endblock %}
    <script src="https://code.jquery.com/jquery-3.3.1.js"></script>
</head>
<body class="bg-gradient-primary">
<div class="container">
    <h1 class="tet" align="center">BIENVENUE SUR CARLINBLEU</h1>
    <h4 align="center" style="color:#efd807; "> SHOWROOMS & PROJETS</h4>
    <div class="card o-hidden border-0 shadow-lg my-5 addur" >
        <div class="card-body p-0">
            <!-- Nested Row within Card Body -->
            <div class="row">

                <div class="col-lg-5 d-none d-lg-block">
                    {% if type == 'moncompte' %}
                    <img src="{{ asset('img/compte.png') }}" style="width: 380px">
                    {% endif %}

                    {% if type == 'abonnement' %}
                        <h1 class="text-pri" style="margin: 50px 0 0 80px"> Heureux de<br>vous revoir !</h1>
                    {% endif %}

                </div>
                <div class="col-lg-7">
                    <div style="padding: 40px 40px 10px 20px">
                        {% if type == 'moncompte' %}
                        <div class="text-center">
                            <h1 class="h4 text-gray-900 mb-4">Créer mon compte</h1>
                            <h1 class="h6 mb-4" style="color: red"></h1>
                        </div>

                        {{ form_start(formCompte, {'attr': {'novalidate': 'novalidate'}}) }}
                          {{ form_row(formCompte._token) }}
                        <form class="user" method="post" action="">
                            <div class="form-group row">
                                <div class="col-sm-6 mb-3 mb-sm-0">
                                    {{ form_widget(formCompte.nom,{'attr':{'class':'form-control form-control-user','placeholder':'Nom'}})}}
                                    {{ form_errors(formCompte.nom) }}
                                </div>
                                <div class="col-sm-6">
                                    {{ form_widget(formCompte.prenoms,{'attr':{'class':'form-control form-control-user','placeholder':'Prenoms'}})}}
                                    {{ form_errors(formCompte.prenoms) }}
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-sm-6 mb-3 mb-sm-0">
                                    {{ form_widget(formCompte.societe,{'attr':{'class':'form-control form-control-user','placeholder':'Société'}})}}
                                    {{ form_errors(formCompte.societe) }}
                                </div>
                                <div class="col-sm-6 mb-3 mb-sm-0">
                                    {{ form_widget(formCompte.pays,{'attr':{'class':'form-control form-control-user','placeholder':'Pays'}})}}
                                    {{ form_errors(formCompte.pays) }}
                                </div>
                            </div>
                            <div class="form-group">

                            </div>
                            <div class="form-group row">
                                <div class="col-sm-6 mb-3 mb-sm-0">
                                    {{ form_widget(formCompte.username,{'attr':{'class':'form-control form-control-user','placeholder':'Email'}})}}
                                    {{ form_errors(formCompte.username) }}
                                </div>
                                <div class="col-sm-6">
                                    {{ form_widget(formCompte.contact,{'attr':{'class':'form-control form-control-user','placeholder':'Contact'}})}}
                                    {{ form_errors(formCompte.contact) }}
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-sm-6 mb-3 mb-sm-0">
                                    {{ form_widget(formCompte.password,{'attr':{'class':'form-control form-control-user','placeholder':'Mot de passe'}})}}
                                    {{ form_errors(formCompte.password) }}
                                </div>
                                <div class="col-sm-6">
                                    {{ form_widget(formCompte.confirm_passe,{'attr':{'class':'form-control form-control-user','placeholder':'confirmer le mot de passe'}})}}
                                    {{ form_errors(formCompte.confirm_passe) }}
                                </div></div>
                                <div class="form-group">
                                    {{ form_widget(formCompte.adresse,{'attr':{'class':'form-control form-control-user','placeholder':'Situation géographique de votre société'}})}}
                                    {{ form_errors(formCompte.adresse) }}
                                </div>

                            {{ form_widget(formCompte.save,{ 'label': 'Créer mon compte' })}}
                        </form>
                        {{ form_end(formCompte) }}
                        {% endif %}
                        {% if type == 'abonnement' %}
                            <img src="{{ asset('img/abonnement.png') }}" style="width: 100%; margin: 0">
                        {% endif %}
                        {% if type == 'success' %}
                            <h2 class="text-pri">Félicitations !</h2>
                        <h6>Nous vous remercions de votre paiement.<br><br>Votre transaction est terminée et vous allez recevoir par email un avis accusant réception de votre achat.<br><br>
                            Connectez-vous à votre compte PayPal pour afficher les détails de la transaction.<br><br>
                            <a href="{{ path('content') }}">Retourner à la page d'accueil</a>
                        </h6>

                        {% endif %}


                    </div>

                </div>
            </div>
        </div>
    </div>

</div>

