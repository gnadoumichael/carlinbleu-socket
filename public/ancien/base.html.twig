                <script>

                    // PARTAGE: AJOUTER UN ARTICLE
                    function addarticle(id) {
                        $('#dataPARTAGER').hide();
                        document.getElementById('spinnerPARTA').style.visibility = "visible";
                        axios({
                            method: 'post',
                            url: '/partage/article/' + id,
                        })
                            .then(function (response) {
                                $('#dataPARTAGER').visible();
                                document.getElementById('spinnerPARTA').style.visibility = "hide";
                            })
                            .catch(function (error) {
                                console.log(error);
                            });
                    }

                    function gaoula(operation, ou, id, type, num) {
                        var nbre = document.getElementById(id).value;
                        axios({
                            method: 'post',
                            url: '/provider/' + num + '/' + type + '/' + operation + '/' + nbre + '/' + ou,
                        })
                            .then(function (response) {
                                location.reload();
                            })
                            .catch(function (error) {
                                console.log(error);
                            });
                    }

                    function fpen() {
                        document.getElementById('mate').style.display = 'inline';
                    }

                    // AJOUTE LES DOMAINES DANS UN COMPTE
                    function buble(a) {
                        axios({
                            method: 'post',
                            url: '/moncompte/' + a,
                        })
                            .then(function (response) {
                                console.log(response);
                            })
                            .catch(function (error) {
                                console.log(error);
                            });
                    }

                    function printDiv() {
                        var divToPrint = document.getElementById('DivIdToPrint');
                        var newWin = window.open('', 'Print-Window');

                        newWin.document.open();
                        newWin.document.write('<html><body onload="window.print()">' + divToPrint.innerHTML + '</body></html>');
                        newWin.document.close();

                        setTimeout(function () {
                            newWin.close();
                        }, 10);
                    }
                </script>
                <script src="https://unpkg.com/axios/dist/axios.min.js"></script>
                <script>
                    $(function () {
                        $('.lazy').lazy({
                            placeholder: "data:image/gif;base64,R0lGODlhEALAPQAPzl5uLr9Nrl8e7..."
                        });
                    });

                    function aamigrate(a) {
                        axios({
                            method: 'post',
                            url: '/article/migrate/' + a,
                        })
                            .then(function (response) {
                                if (response.data.info == 'new') {
                                    document.getElementById(response.data.id).innerText = "Article ajouté";
                                    document.getElementById(response.data.id).className = "btn btn-sm btn-warning";
                                } else {
                                    document.getElementById(response.data.id).innerText = "Ajouter cet article";
                                    document.getElementById(response.data.id).className = "btn btn-sm btn-primary";
                                }
                            })
                            .catch(function (error) {
                                console.log(error);
                            });
                    }

                    function fchange() {
                        location.reload();
                    }

                    function avente(a) {
                        axios({
                            method: 'post',
                            url: '/article/vente/' + a,
                        })
                            .then(function (response) {
                                console.log(response);
                                if (response.data.info == 'oui') {
                                    location.reload();
                                }
                            })
                            .catch(function (error) {
                                console.log(error);
                            });
                    }


                    function affiche(event) {
                        axios({
                            method: 'post',
                            url: '/content/' + this.value,
                        })
                            .then(function (response) {
                                obj = JSON.parse(response.data.result);
                                if (obj[0].count == 0) {
                                    document.getElementById('contenu').style.visibility = 'hidden';
                                } else {
                                    document.getElementById('don').innerHTML = " ";
                                    document.getElementById('contenu').style.visibility = 'visible';
                                    var j = obj[0].count + 1;
                                    for (i = 1; i <= j; i++) {
                                        var a = document.createElement("A");
                                        a.setAttribute("href", "/search/" + obj[i].desi);
                                        var tr = document.createElement("tr");
                                        var td1 = document.createElement("td");
                                        var t1 = document.createTextNode(obj[i].desi);
                                        a.appendChild(t1);
                                        td1.appendChild(a);

                                        tr.appendChild(td1);

                                        document.getElementById('don').appendChild(tr)
                                    }
                                }
                            })
                            .catch(function (error) {
                                console.log(error);
                            });
                    }

                    function affich(event) {
                        window.location.replace('/search/' + document.getElementById('recher').value);
                    }

