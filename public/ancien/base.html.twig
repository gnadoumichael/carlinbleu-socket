                    // AFFICHE UN ARTICLE
                    $('.refarticle').on('input', function (e) {
                        var a = document.getElementById('form_code').value;
                        if (a.length > 2) {
                            axios({
                                method: 'post',
                                url: '/search/content/' + a + '/articles',
                            })
                                .then(function (response) {
                                    console.log(response);
                                    document.getElementById('form_articles').innerHTML = " ";
                                    obj = JSON.parse(response.data.result);
                                    var j = obj[0].count + 1;
                                    if (obj[0].count === 1) {
                                        document.getElementById('form_reference').value = obj[1].refe;
                                    }
                                    for (i = 1; i <= j; i++) {
                                        var iden = obj[i].iden;
                                        var desi = obj[i].desi;

                                        var opt = document.createElement("OPTION");
                                        opt.setAttribute("value", iden);
                                        var t = document.createTextNode(desi);
                                        opt.appendChild(t);
                                        document.getElementById('form_articles').appendChild(opt)

                                    }

                                })
                                .catch(function (error) {
                                    console.log(error);
                                });
                        }
                    });


                    // AFFICHE LA REFERENCE D'UN ARTICLE
                    $('#form_articles').change(function (e) {
                        var val = $("#form_articles option:selected").text();
                        axios({
                            method: 'post',
                            url: '/search/content/articles/reference/' + val + '/refere',
                        })
                            .then(function (response) {
                                obj = JSON.parse(response.data.result);
                                document.getElementById('form_reference').value = obj[0].refe;
                            })
                            .catch(function (error) {
                                console.log(error);
                            });

                    });


                    // AFFICHE LA REFERENCE D'UN ARTICLE
                    function sho(a) {
                        document.getElementById('mevalue').innerHTML = a;
                        $('#pays').modal('toggle');
                    }

                    $("#choipays").change(function () {
                        var a = document.getElementById('mevalue').innerHTML;
                        var id = $("#choipays").val();
                        window.location.href = "https://carlinbleu.com/partage/" + a + "/" + id;
                    });

                    //RECHARGER LA PAGE
                    const perfEntries = performance.getEntriesByType("navigation");
                    if (perfEntries[0].type === "back_forward") {
                        location.reload()
