              <span style="font-size: 13px; color: #FFF">©<script>
                  document.write(new Date().getFullYear())
                </script>Carlingroup. Tous droits réservés. Application sous licence.</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <p style="font-size: 13px; color: #FFF; text-align: right">Assistance & Contact: contact@carlingroup.com</p>
                    </div>
                </div><!-- Row end -->

                <div id="back-to-top" data-spy="affix" data-offset-top="10" class="back-to-top position-fixed">
                    <button class="btn btn-primary" title="Back to Top">
                        <i class="fa fa-angle-double-up"></i>
                    </button>
                </div>

            </div><!-- Container end -->
        </div><!-- Copyright end -->
