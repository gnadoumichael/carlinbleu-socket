<body>
<div class="body-inner">
    <div id="top-bar" class="top-bar" style="background-color: #4e73df">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 col-md-8">
                    <ul class="top-info text-center text-md-left">
                        <li><h1 class="info-text" style="color: #fff; margin-top: 10px"><img src="cover/images/72.png">Carlinbleu</h1></li>
                    </ul>
                </div>
                {% if not ismobile %}
                <div class="col-lg-4 col-md-4" style="padding-top: 15px; text-align: center">
                    <div class="row">
                        <div class="col-md-6"><a href="{{ path('login') }}" style="color: #fff; font-weight: 600; float: right">Se connecter<br><img src="/images/log.png" style="width: 40px"></a></div>
                    </div>
                </div>
                {% endif %}
            </div>
            {% if ismobile %}
                <table style="width: 100%; text-align: center">
                    <tr>
                        <td><a href="{{ path('login') }}" style="color: #fff; font-weight: 600;">Se connecter<br><img src="/images/log.png" style="width: 40px"></a></td>
                        <td><a href="{{ path('app_register') }}" style="color: #fff; font-weight: 600; ">Créer un compte<br><img src="/images/adduser.png" style="width: 40px"></a></td>
                    </tr>
                </table>
            {% endif %}
        </div>
    </div>
    <header id="header" class="header-one">
        <div class="site-navigation">
            <div class="container">

                <div class="nav-search">
                    <span id="search"><i class="fa fa-search"></i></span>
                </div>

                <div class="search-block" style="display: none;">
                    <label for="search-field" class="w-100 mb-0">
                        <input type="text" class="form-control" id="search-field"
                               placeholder="Type what you want and enter">
                    </label>
                    <span class="search-close">&times;</span>
                </div><!-- Site search end -->
            </div>
            <!--/ Container end -->

        </div>
        <!--/ Navigation end -->
    </header>
    <!--/ Header end -->
    <div id="banner-area" class="banner-area" style="background-image:url('cover/images/banner/banner1.jpg'); background-color: #4e73df">
        <div class="banner-text">
            <div class="container">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="banner-heading">
                            <h4 class="banner-title" style="font-size: 40px; line-height: 1">APPLICATION DE SUIVI DE CHANTIERS</h4>
                            <h3 style="color: yellow">Tout ce dont vous aurez BESOIN pour<br> la gestion de vos
                                chantiers !</h3>
                        </div>
                    </div><!-- Col end -->
                </div><!-- Row end -->
            </div><!-- Container end -->
        </div><!-- Banner text end -->
    </div><!-- Banner area end -->

    <section id="main-container" class="main-container">
        <div class="container">
            <div class="row">
                <div class="col-lg-9">
