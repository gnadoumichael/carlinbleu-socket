    <!-- Slick Carousel -->
    <script src="cover/plugins/slick/slick.min.js"></script>
    <script src="plugins/slick/slick-animation.min.js"></script>
    <!-- Color box -->
    <script src="cover/plugins/colorbox/jquery.colorbox.js"></script>
    <!-- shuffle -->
    <script src="cover/plugins/shuffle/shuffle.min.js" defer></script>


    <!-- Google Map API Key-->
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCcABaamniA6OL5YvYSpB3pFMNrXwXnLwU" defer></script>
    <script src="cover/js/script.js"></script>

</div>
<script type="module">
    import { createChat } from 'https://cdn.jsdelivr.net/npm/@n8n/chat/dist/chat.bundle.es.js';
    createChat({
        webhookUrl: 'https://mikieing.app.n8n.cloud/webhook/0faa2170-061e-4a4e-a1c4-5ea192b7a405/chat',
        defaultLanguage: 'fr',webhookConfig: {
            method: 'POST',
            headers: {}
        },
        target: '#n8n-chat',
        mode: 'window',
        chatInputKey: 'chatInput',
        chatSessionKey: 'sessionId',
        metadata: {},
        showWelcomeScreen: false,
        initialMessages: [
            'Bonjour! 👋',
            'Mon nom est Michael. Comment puis-je vous aider?'
        ],
        i18n: {
            fr: {
                title: 'Salut! 👋',
                subtitle: "Commencez une discussion. Nous sommes là pour vous aider 24h/24 et 7j/7.",
                footer: '',
                getStarted: 'Nouvelle Conversation',
                inputPlaceholder: 'Veuillez taper votre question..',
            },
        },
    });
</script>

