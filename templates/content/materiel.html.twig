                                                                <span class="label bg-pink font-12"> {{ matpr.mouvement|upper }}</span>
                                                            {% endif %}
                                                        </td>
                                                        <td class="text-center bolo600"><span class="label bg-green font-12">{{ matpr.quantite }}</span></td>
                                                    </tr>
                                                {% endfor %}
                                                </tbody>
                                            </table>
                                            <br></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
