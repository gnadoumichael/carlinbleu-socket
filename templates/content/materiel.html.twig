                                                        <td title="{{ materiel.code }}"
                                                            class="bolo600 text-center">{{ materiel.code }}</td>
                                                        <td title="{{ materiel.materiel }}"
                                                            class="col-blue bolo600">{{ materiel.materiel }}</td>
