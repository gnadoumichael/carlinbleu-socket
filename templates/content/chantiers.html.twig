                                                                           title="{{ chantier.nomchantier }}"
                                                                           class="bolo600">
                                                                            {% if chantier.sous is not null %}
                                                                                <span class="badge bg-orange">SC</span>
                                                                            {% endif %}
                                                                            {{ chantier.nomchantier|upper|u.truncate(30, '...', false) }}
                                                                        </a>
