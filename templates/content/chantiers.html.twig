                    {% set countEtude = 0 %}
                    {% set countEchouer = 0 %}
                    {% set countEncours = 0 %}
                    {% set countSous = 0 %}
                    {% set countTerminer = 0 %}
                    {% set countCloturer = 0 %}
                    {% set countTout = 0 %}

