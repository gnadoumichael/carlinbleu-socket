                            padding: 5px;
                        }


                        td.bord {
                            border: 0 solid #FFFFFF !important;
                            padding: 5px;
                            text-align: right;
                            font-weight: 600;
                        }

                        td.bordz {
                            border: 0 solid #FFFFFF !important;
                            padding: 0 0 0 5px !important;
                        }

