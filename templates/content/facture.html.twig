                                                       class="sholigne">
                                                        <i class="fa fa-trash col-pink" aria-hidden="true"
                                                           title="Supprimer"></i>
                                                    </a></td>
                                            {% endif %}
                                        </tr>
                                        {% set st = (lign.pu * lign.quantite)+ st %}
                                    {% endfor %}
                                {% endfor %}
                                {# FIN GROUPE ET LIGNE #}

                                {# LIGNE SANS GROUPE #}
                                {% for lign in lignes %}
                                    {% if lign.groupe is null %}
                                        <tr>
                                            <td>
                                                <span class="pri font-bold">{{ lign.designation|raw }}</span><br>
                                                <table style="width: 100%; margin-top: 10px">
