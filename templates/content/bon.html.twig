                    {% if app.user %}
                        <li class="col-yellow h4 bolo600 m-l-20">
                            {{ app.user.nom|upper }}
                            {{ app.user.prenoms|upper }}
                        </li>
                    {% endif %}
                {% endif %}

                {% if app.user %}
                    {% if libre is not defined and app.user %}
                        <li class="hidere">
                            <a href="javascript:void(0);" data-close="true">
                    <span class="js-right-sidebars badge bg-pink">
                      CHANTIERS EN COURS
                    </span>
                            </a>
                        </li>
                    {% endif %}
                    <li class="hidere">
