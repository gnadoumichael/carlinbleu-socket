                                    font-size: {{ formes.piedsize }}px;
                                    text-align:center; padding-left:1cm;
                                    padding-right:1cm">{{ formes.pied }}</p>
                        {% endif %}
                        {% if formes.typeFooter is same as "image" %}

                            <img src="https://www.carlinbleu.com/gallery/{{ formes.footerImage }}"
                                style="width: 21cm;min-height: {{ formes.footerHeight }}cm"
                                alt=""/>

                        {% endif %}
