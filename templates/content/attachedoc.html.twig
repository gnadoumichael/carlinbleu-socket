                            {% endif %}

                            {% if formes.typeEntete is same as "texte" %}
                                <p class="cocolor" style="
                                        padding-right: {{ formes.teteDD }} cm;
                                        padding-left: {{ forme.steteDG }}cm;
                                        padding-top: {{ formes.teteDH }}cm;
                                        padding-bottom: {{ formes.teteDB }}cm">{{ formes.headerText }}</p>
                            {% endif %}
                        {% endif %}

                    {% endif %}
                </header>
                <footer class="footer">
                    {% if formes.pied is not same as "aucun" %}
                        {% if formes.typeFooter is same as "texte" %}
